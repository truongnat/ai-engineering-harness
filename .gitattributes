# Auto normalize line endings to LF across all platforms
* text=auto

# Explicitly set LF for source files
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.ts text eol=lf
*.tsx text eol=lf

# Binary files
*.png binary
*.jpg binary
*.gif binary
*.mp4 binary
*.zip binary
